# Plantilla de credenciales para ejecutar los scripts de scripts/ en local.
#
# Copia este fichero a `.env.local` (ya está en .gitignore, nunca se sube) y
# rellena los valores reales. NUNCA pongas valores reales en este fichero
# (.env.example) ni los commitees al repo, que es público.
#
# Importante: los secrets de GitHub Actions son de solo escritura — una vez
# configurados en Settings > Secrets, no se pueden volver a leer desde la UI
# ni la API. Si no guardaste estos valores en otro sitio (gestor de
# contraseñas, etc.) al crearlos, tendrás que regenerarlos siguiendo
# docs/DEPLOYMENT.md (tokens de Cloudflare) o repetir el flujo OAuth
# (refresh token de Blogger). Las instrucciones de cada variable están abajo.
#
# Estos mismos nombres son los Secrets configurados en GitHub
# (Settings > Secrets and variables > Actions) para que el workflow
# .github/workflows/deploy.yml funcione en CI.

# --- Cloudflare Pages (docs/DEPLOYMENT.md, sección 1) ---

# Token con scope "Account > Cloudflare Pages > Edit".
# Dashboard de Cloudflare > My Profile > API Tokens > Create Token.
CLOUDFLARE_API_TOKEN=tu-token-de-pages-aqui

# Cloudflare dashboard > barra lateral derecha, o:
# curl -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" https://api.cloudflare.com/client/v4/accounts
CLOUDFLARE_ACCOUNT_ID=tu-account-id-aqui

# Nombre del proyecto Pages (ver docs/DEPLOYMENT.md 1.1)
CLOUDFLARE_PAGES_PROJECT=nombre-del-proyecto-pages

# Token SEPARADO con scope "Zone > DNS > Edit" sobre la zona easyleads.es.
# Necesario solo para scripts/cf_create_subdomain.py o para crear/editar
# registros CNAME manualmente (docs/DEPLOYMENT.md 1.2). No se usa en CI.
CLOUDFLARE_DNS_TOKEN=tu-token-de-dns-aqui

# Zone ID de easyleads.es en Cloudflare (dashboard > Overview > API > Zone ID).
# Solo necesario para crear registros DNS manualmente.
CLOUDFLARE_ZONE_ID=tu-zone-id-aqui

# --- Blogger (docs/DEPLOYMENT.md, sección 3) ---

# ID numérico del blog (Blogger > Configuración > ID del blog en la URL del panel).
BLOGGER_BLOG_ID=tu-blog-id-aqui

# Credenciales OAuth tipo "Desktop app" en Google Cloud Console
# (proyecto con la Blogger API v3 habilitada).
BLOGGER_OAUTH_CLIENT_ID=tu-client-id-aqui
BLOGGER_OAUTH_CLIENT_SECRET=tu-client-secret-aqui

# Se obtiene una sola vez con el flujo manual descrito en
# docs/DEPLOYMENT.md 3.2. Caduca a los 7 dias si la pantalla de
# consentimiento OAuth sigue en estado "Testing" (debe estar "In production").
BLOGGER_REFRESH_TOKEN=tu-refresh-token-aqui

# --- Tumblr (docs/DEPLOYMENT.md, sección 4) ---

# Hostname completo del blog de destino (dominio personalizado si lo tiene).
TUMBLR_BLOG_IDENTIFIER=easyleads.tumblr.com

# App creada en https://www.tumblr.com/oauth/apps.
TUMBLR_CONSUMER_KEY=tu-consumer-key-aqui
TUMBLR_CONSUMER_SECRET=tu-consumer-secret-aqui

# Generados una sola vez desde el "Explore API" de la app (OAuth 1.0a,
# no expiran salvo que se revoquen desde la cuenta de Tumblr).
TUMBLR_OAUTH_TOKEN=tu-oauth-token-aqui
TUMBLR_OAUTH_TOKEN_SECRET=tu-oauth-token-secret-aqui

# --- Generación de contenido (scripts/generate_content.py, opcional) ---

# https://console.anthropic.com/settings/keys — necesaria solo si vas a
# generar borradores de contenido largo con la API de Claude. No se usa en CI.
ANTHROPIC_API_KEY=tu-api-key-aqui

# --- IndexNow (scripts/submit_indexnow.py) ---

# Clave generada por el propio script en sites/dist/<INDEXNOW_KEY>.txt durante
# el build (ver sites/scripts/write-indexnow-key.mjs); no es un secreto que
# tengas que generar tu mismo, pero si quieres fijarla en vez de que se
# regenere en cada build, ponla aqui.
INDEXNOW_KEY=clave-indexnow-aqui
