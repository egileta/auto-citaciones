---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { LoadedPost } from '../lib/posts';
import { getProjectBySlug } from '../lib/projects';
import type { LinkWheelEntry } from '../lib/linkWheel';

interface Props {
  post: LoadedPost;
  canonicalUrl: string;
  citationUrl: string;
  html: string;
  linkWheel: LinkWheelEntry[];
}

const { post, canonicalUrl, citationUrl, html, linkWheel } = Astro.props;
const project = getProjectBySlug(post.projectSlug)!;
---
<BaseLayout
  title={post.frontmatter.title}
  description={post.frontmatter.title}
  canonicalUrl={canonicalUrl}
>
  <article>
    <h1>{post.frontmatter.title}</h1>
    <time datetime={post.frontmatter.date}>{post.frontmatter.date}</time>
    <div set:html={html} />
    <p><a href={citationUrl}>Volver a la página de {project.name}</a></p>
  </article>
  <address>
    {project.name}<br />
    {project.nap.streetAddress}<br />
    {project.nap.postalCode} {project.nap.addressLocality}<br />
    Tel: {project.nap.telephone}<br />
    Web: <a href={project.website}>{project.website}</a>
  </address>
  {linkWheel.length > 0 && (
    <>
      <h2>También puedes leer</h2>
      <ul>
        {linkWheel.map((entry) => (
          <li><a href={entry.url}>{entry.title}</a></li>
        ))}
      </ul>
    </>
  )}
</BaseLayout>
